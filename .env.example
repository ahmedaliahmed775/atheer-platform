# ════════════════════════════════════════
# Atheer Platform — متغيرات البيئة (Docker Compose)
# انسخ هذا الملف إلى .env وعدّل القيم
# ════════════════════════════════════════

# ── قاعدة البيانات ──
POSTGRES_DB=atheer
POSTGRES_USER=atheer
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── السويتش (تُمرَّر كمتغيرات بيئة للحاوية) ──
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
KMS_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── الداشبورد ──
# للتطوير المحلي:
NEXT_PUBLIC_API_URL=http://localhost:8080
# لـ Docker (يُمرَّر وقت البناء عبر build.args):
# NEXT_PUBLIC_API_URL=http://atheer-switch:8080

# ── قاعدة البيانات (Docker فقط) ──
# DB_HOST=postgres
# DB_SSL_MODE=disable
