# ═══════════════════════════════════════════════
# Atheer Platform — Environment Variables
# ═══════════════════════════════════════════════

# Server
ATHEER_SERVER_PORT=8080
ATHEER_ENV=development
LOG_LEVEL=DEBUG

# Database (sslmode=require in production)
DATABASE_URL=postgres://atheer:${DB_PASSWORD}@localhost:5432/atheer?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=${REDIS_SECRET}

# KMS — Seed encryption key (32 bytes base64-encoded)
# Generate: openssl rand -base64 32
KMS_MASTER_KEY=${KMS_KEY}

# TLS (production — required for mTLS)
TLS_CERT_PATH=
TLS_KEY_PATH=
MTLS_CLIENT_CA_PATH=

# Play Integrity
PLAY_INTEGRITY_PROJECT_ID=${PI_PROJECT_ID}

# Rate Limits
ATHEER_LIMITS_RATE_LIMIT_PER_DEVICE=10
ATHEER_LIMITS_RATE_LIMIT_PER_WALLET=100
ATHEER_LIMITS_RATE_LIMIT_PER_IP=50
